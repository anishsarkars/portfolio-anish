---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Loader from '../components/Loader.astro';
import AmbientMode from '../components/AmbientMode.astro';
import UserCursor from '../components/UserCursor.tsx';
import Sparkles from '../components/Sparkles.tsx';
import CurvedMarquee from '../components/CurvedMarquee.tsx';
import CommandMenu from '../components/CommandMenu.tsx';
import { FooterBrand } from '../components/name-brand';
import { AutoTOCMinimap } from '../components/auto-toc-minimap';
import { profile } from '../data/profile';
import { projects } from '../data/projects';
import Analytics from '@vercel/analytics/astro';
// `toc` selects which headings become scroll-minimap ticks (section h2s by default).
// `image` is the social card; pages (e.g. blog posts) can pass their own.
const {
  title = 'Anish Sarkar · Design & Product Engineer',
  description = 'I build products from scratch. Founder building ZELP, an AI-powered healthcare platform, and shipping products people actually use.',
  image = '/og.png',
  ogType = 'website',
  toc = 'main h2',
} = Astro.props;
const siteName = 'Anish Sarkar';
// Always point canonical at the configured production domain (Astro.site),
// so a workers.dev or any mirror host can't compete for ranking.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
// Social scrapers need an absolute image URL.
const ogImage = new URL(image, Astro.site ?? Astro.url).href;
const commandItems = [
  { label: 'Home', href: '/', group: 'Pages' },
  { label: 'Projects', href: '/projects', group: 'Pages' },
  ...projects.map((p) => ({
    label: p.title,
    href: p.liveLink ?? p.githubLink ?? '/projects',
    group: 'Projects',
    external: true,
    keywords: [p.description, p.impact].filter(Boolean) as string[],
  })),
  ...profile.socials.map((s) => ({ label: s.label, href: s.href, group: 'Links', external: true })),
  { label: 'Email', href: `mailto:${profile.email}`, group: 'Links', external: true },
  { label: 'Book a call', href: profile.bookCall, group: 'Links', external: true },
  { label: 'Website', href: profile.website, group: 'Links', external: true },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph (LinkedIn, Discord, Slack, Facebook) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- X / Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <script is:inline>
      const t = localStorage.getItem('theme');
      const dark = t ? t === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', dark);
      // Intro loader: shows on every page load (lock scroll before paint).
      document.documentElement.classList.add('loading');
    </script>
    <script defer src="https://cdn.databuddy.cc/databuddy.js"></script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Loader />
    <div id="sparkles-layer" class="pointer-events-none fixed inset-0 z-0 opacity-0 transition-opacity duration-700" aria-hidden="true">
      <Sparkles client:idle densityScale={0.18} particleColor="rgba(255, 203, 203, 0.4)" />
    </div>
    <!-- Grid system: the content lives on a centered "sheet" framed by vertical
         hairlines; full-bleed horizontal hairlines divide it at real section
         boundaries. Same frame on every page. -->
    <main class="relative z-10 mx-auto min-h-dvh max-w-2xl border-x border-border px-6">
      <Nav />
      <div class="-mx-6 border-b border-border" aria-hidden="true"></div>
      <nav aria-label="On this page" class="fixed top-1/2 right-6 z-40 hidden -translate-y-1/2 xl:block">
        <!-- client:idle, not client:visible: the island renders empty until headings load,
             so a visibility trigger would never fire (zero-size element never intersects). -->
        <AutoTOCMinimap client:idle selector={toc} />
      </nav>
      <slot />
      <footer class="-mx-6 mt-4 border-t border-border px-6 pt-3">
        <div class="pointer-events-none relative left-1/2 z-40 h-[11vw] max-h-40 w-screen -translate-x-1/2 overflow-hidden text-foreground/55 [&>astro-island]:block [&>astro-island]:size-full">
          <CurvedMarquee
            client:visible
            text="thanks"
            baseVelocity={21}
            gap={14}
            fadePercent={12}
            curveAmount={-30}
            color="currentColor"
            font={{ fontFamily: 'inherit', fontWeight: 600, fontSize: 60, letterSpacing: '1px', lineHeight: '1em' }}
          />
        </div>
        <div class="-mx-6 aspect-[22/3] overflow-hidden text-foreground [&>astro-island]:block [&>astro-island]:size-full">
          <FooterBrand client:visible />
        </div>
      </footer>
    </main>
    <CommandMenu client:idle items={commandItems} />
    <AmbientMode />
    <UserCursor client:load name="hi" size={31} />
    <Analytics />
  </body>
</html>
