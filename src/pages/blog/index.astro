---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
// Keystatic stores entries as {slug}/index.mdoc, so id = "hello-world/index"
// Strip the trailing /index to get clean slugs for URLs
const toSlug = (id: string) => id.replace(/\/index$/, '');
---
<Base title="Blog — Anish Sarkar" toc="main h3">
  <h1 class="pt-10 text-2xl font-semibold">Blog</h1>
  <div class="mt-6">
    {posts.map((p) => <BlogCard title={p.data.title} description={p.data.description} pubDate={p.data.pubDate} slug={toSlug(p.id)} />)}
  </div>
</Base>
