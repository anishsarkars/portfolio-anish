---
import Base from '../layouts/Base.astro';
import { HeroRole } from '../components/HeroRole';
import { WorkExperience } from '../components/work-experience';
import HomeProjects from '../components/HomeProjects.astro';
import HeroSocials from '../components/HeroSocials.astro';
import { SpotlightReveal } from '../components/unlumen-ui/spotlight-reveal';
import { profile } from '../data/profile';
import { experience } from '../data/experience';

const metaLabel = 'text-[11px] font-medium uppercase tracking-wider text-muted-foreground';
const metaValue = 'mt-1.5 flex items-center gap-1.5 text-sm text-foreground/90';
const metaIcon = 'size-3.5 shrink-0 text-muted-foreground';
---
<Base>
  <section class="py-10">
    <div class="flex items-center gap-4">
      <div class="flex shrink-0 flex-col items-center gap-2">
        <img
          id="hero-avatar"
          src="/anish.webp"
          alt={profile.name}
          data-real="/anish.webp"
          data-alt="/anish-cartoon.png"
          class="size-14 rounded-2xl object-cover ring-1 ring-border transition-opacity duration-150 sm:size-16"
        />
        <button
          id="avatar-switch"
          type="button"
          role="switch"
          aria-checked="false"
          aria-label="Toggle avatar style"
          title="Toggle avatar"
          class="relative h-4 w-7 rounded-full bg-muted ring-1 ring-border transition-colors duration-200"
        >
          <span
            id="avatar-switch-thumb"
            class="absolute left-0.5 top-0.5 size-3 rounded-full bg-foreground shadow-sm transition-transform duration-200"
          ></span>
        </button>
      </div>
      <div>
        <h1 class="flex items-center gap-1.5 text-2xl font-bold tracking-tight sm:text-3xl">
          <span>{profile.name}</span>
          <svg class="size-5 shrink-0 translate-y-[1px]" viewBox="0 0 22 22" role="img" aria-label="Verified">
            <path fill="#1d9bf0" d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.854-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.688-.13.633-.08 1.29.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.606-.274 1.263-.144 1.896.13.634.433 1.218.877 1.688.47.443 1.054.747 1.687.878.633.132 1.29.084 1.897-.136.274.586.705 1.084 1.246 1.439.54.354 1.17.551 1.816.569.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.239 1.266.296 1.903.164.636-.132 1.22-.447 1.68-.907.46-.46.776-1.044.908-1.681s.075-1.299-.165-1.903c.586-.274 1.084-.705 1.439-1.246.354-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z"/>
          </svg>
        </h1>
        <p class="mt-1"><HeroRole client:visible /></p>
      </div>
    </div>

    <dl class="mt-8">
      <div>
        <dt class={metaLabel}>Location</dt>
        <dd class={metaValue}>
          <svg class={metaIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>{profile.location}</span>
        </dd>
      </div>
    </dl>

    <script is:inline>
      (() => {
        const img = document.getElementById('hero-avatar');
        const sw = document.getElementById('avatar-switch');
        const thumb = document.getElementById('avatar-switch-thumb');
        if (!img || !sw || !thumb) return;
        let on = false;
        let ctx;
        const blip = () => {
          try {
            ctx = ctx || new (window.AudioContext || window.webkitAudioContext)();
            if (ctx.state === 'suspended') ctx.resume();
            const o = ctx.createOscillator();
            const g = ctx.createGain();
            o.connect(g);
            g.connect(ctx.destination);
            o.type = 'triangle';
            o.frequency.setValueAtTime(on ? 720 : 480, ctx.currentTime);
            g.gain.setValueAtTime(0.0001, ctx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.12, ctx.currentTime + 0.008);
            g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.14);
            o.start();
            o.stop(ctx.currentTime + 0.15);
          } catch (e) {}
        };
        sw.addEventListener('click', () => {
          on = !on;
          img.style.opacity = '0';
          setTimeout(() => {
            img.src = on ? img.dataset.alt : img.dataset.real;
            img.style.opacity = '1';
          }, 120);
          sw.setAttribute('aria-checked', String(on));
          sw.classList.toggle('bg-foreground', on);
          sw.classList.toggle('bg-muted', !on);
          thumb.style.transform = on ? 'translateX(12px)' : 'translateX(0)';
          thumb.classList.toggle('bg-background', on);
          thumb.classList.toggle('bg-foreground', !on);
          blip();
        });
      })();
    </script>

    <p class="mt-5 text-sm leading-relaxed text-foreground/75">{profile.bio}</p>

    <HeroSocials />
  </section>

  <section class="-mx-6 border-t border-border px-6 py-10">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Experience</h2>
    <div class="mt-2">
      <WorkExperience client:visible experiences={experience} initialCount={4} className="px-0 bg-transparent" />
    </div>
  </section>

  <section class="-mx-6 border-t border-border px-6 py-10">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Projects</h2>
      <a href="/projects" class="text-xs text-muted-foreground hover:text-foreground">All →</a>
    </div>
    <HomeProjects />
  </section>

  <section class="-mx-6 border-t border-border">
    <SpotlightReveal
      client:only="react"
      baseImage="https://soft-zoom-63098134.figma.site/_assets/v11/5c9f982199fde1d9b85a20e5396f0fa7bacaf9a3.png?w=2560"
      revealImage="https://soft-zoom-63098134.figma.site/_assets/v11/6be2165e31648955b4e071f4cf2a50bc572b9bfd.png?w=1536"
      bigText="Visuals"
      headline="Design & product work — interfaces, brand, and the small details in between."
      ctaLabel="Start a project"
      ctaHref={profile.bookCall}
    />
  </section>
</Base>
