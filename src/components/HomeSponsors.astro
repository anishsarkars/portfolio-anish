---
import SponsorCard from './SponsorCard.astro';
import { fetchSponsors, resolveGithubToken } from '../lib/github';
// Rendered as a server island (server:defer) so it fetches at request time and
// can read the runtime GITHUB_TOKEN Worker secret — the home page itself stays
// prerendered.
const sponsors = (await fetchSponsors(await resolveGithubToken())).slice(0, 6);
---
{sponsors.length > 0 && (
  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Sponsors</h2>
      <a href="/sponsors" class="text-xs text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-50">All →</a>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">{sponsors.map((s) => <SponsorCard {...s} />)}</div>
  </section>
)}
