---
import { ThemeSwitcher } from './theme-switcher';
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
];
---
<nav class="flex items-center justify-end py-6">
  <div class="flex flex-wrap items-center justify-end gap-x-3 gap-y-2 text-sm sm:gap-x-4">
    {links.map((l) => <a href={l.href} class="hover:underline">{l.label}</a>)}
    <button type="button" aria-label="Open command menu" title="Search (⌘K)"
      onclick="window.dispatchEvent(new Event('open-command-menu'))"
      class="hidden items-center rounded border border-black/15 px-1.5 py-0.5 text-xs text-zinc-500 transition-colors hover:text-zinc-900 sm:inline-flex dark:border-white/15 dark:hover:text-zinc-50">⌘K</button>
    <ThemeSwitcher client:load />
  </div>
</nav>
