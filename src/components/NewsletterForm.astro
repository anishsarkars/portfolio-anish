---
interface Props { title?: string; blurb?: string; }
const { title = 'Newsletter', blurb = 'I share what I learn.' } = Astro.props;
const substackUrl = 'https://kartiklabhshetwar.substack.com';
---
<section class="mt-12 w-full max-w-xl rounded-lg border border-black/10 p-5 dark:border-white/10">
  <h2 class="font-semibold">{title}</h2>
  <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
    {blurb}
  </p>
  <div class="mt-3">
    <a
      href={substackUrl}
      target="_blank"
      rel="noopener"
      class="inline-flex rounded-md bg-zinc-900 px-4 py-2 text-sm text-white transition-opacity hover:opacity-85 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 focus:ring-offset-white dark:bg-white dark:text-zinc-900 dark:focus:ring-zinc-500 dark:focus:ring-offset-zinc-950"
    >
      Subscribe on Substack
    </a>
  </div>
</section>
