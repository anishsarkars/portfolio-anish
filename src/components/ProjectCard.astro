---
interface Props { title: string; description: string; impact?: string; stars?: number; liveLink?: string; githubLink?: string; }
const { title, description, impact, stars, liveLink, githubLink } = Astro.props;
---
<div class="border-b border-black/10 py-6 dark:border-white/10">
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="min-w-0 font-semibold">{title}</h3>
    {impact && <span class="shrink-0 text-xs font-medium text-zinc-700 dark:text-zinc-300">{impact}</span>}
  </div>
  <p class="mt-2 max-w-prose text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{description}</p>
  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-zinc-500">
    {liveLink && (
      <a href={liveLink} target="_blank" rel="noopener" class="hover:text-zinc-900 dark:hover:text-zinc-50">Live ↗</a>
    )}
    {githubLink && (
      <a href={githubLink} target="_blank" rel="noopener" aria-label={`${title} on GitHub`}
        class="inline-flex items-center gap-1.5 hover:text-zinc-900 dark:hover:text-zinc-50">
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        {typeof stars === 'number' && stars > 0 && <span>{stars.toLocaleString()}</span>}
      </a>
    )}
  </div>
</div>
