---
// Ambient "Japanese" mode: a subtle site-wide vibe toggle.
// When on, background music fades in and sakura petals drift through the air
// with a faint warm wash over the whole portfolio. Preference is remembered.
const track = '/music/hitslab-japan-japanese-music-502006.mp3';
---

<div
  id="ambient-petals"
  class="pointer-events-none fixed inset-0 z-[60] overflow-hidden opacity-0 transition-opacity duration-700"
  aria-hidden="true"
></div>

<button
  id="ambient-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Toggle ambient music"
  title="Ambient mode"
  class="fixed bottom-5 right-5 z-[70] flex size-11 items-center justify-center rounded-full border border-border bg-background/70 text-foreground/70 shadow-sm backdrop-blur transition-colors hover:text-foreground"
>
  <svg class="ambient-icon size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9 18V5l12-2v13" />
    <circle cx="6" cy="18" r="3" />
    <circle cx="18" cy="16" r="3" />
  </svg>
  <span class="ambient-bars hidden items-end gap-[3px]" aria-hidden="true">
    <i></i><i></i><i></i>
  </span>
</button>

<div id="ambient-hint" class="pointer-events-none fixed bottom-[4.6rem] right-4 z-[71] flex items-end gap-2 opacity-0" aria-hidden="true">
  <span class="hint-bubble">Turn on sound</span>
  <span class="hint-samurai">
    <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <!-- maedate crest (crescent) -->
      <path d="M9 17C9 6 39 6 39 17C33 10 15 10 9 17Z" fill="var(--samurai-gold)" />
      <!-- helmet dome -->
      <path d="M11 30C11 18 37 18 37 30Z" fill="var(--samurai-dark)" />
      <path d="M24 19V30" stroke="var(--samurai-gold)" stroke-width="1.2" stroke-linecap="round" />
      <!-- fukigaeshi side flares -->
      <path d="M10 29L6 32L12 33Z" fill="var(--samurai-gold)" />
      <path d="M38 29L42 32L36 33Z" fill="var(--samurai-gold)" />
      <!-- menpo face -->
      <path d="M15 30H33V33C33 38 15 38 15 33Z" fill="var(--samurai-face)" />
      <path d="M18.5 33.2H22.5M25.5 33.2H29.5" stroke="var(--samurai-dark)" stroke-width="1.6" stroke-linecap="round" />
    </svg>
  </span>
</div>

<audio id="ambient-audio" src={track} loop preload="none"></audio>

<style>
  #ambient-petals::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 60% at 50% -10%, rgba(255, 183, 206, 0.12), transparent 62%);
    animation: air-breathe 14s ease-in-out infinite alternate;
  }

  /* shared falling particles: petals, leaves, flakes */
  #ambient-petals .p {
    position: absolute;
    top: 0;
    left: var(--x, 50vw);
    will-change: transform, opacity;
    animation: drift-fall var(--fall, 14s) linear infinite;
    animation-delay: var(--delay, 0s);
  }
  #ambient-petals .p > i {
    display: block;
    width: var(--w, 12px);
    height: var(--h, 10px);
    opacity: var(--o, 0.7);
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.05));
  }
  /* petal shape */
  #ambient-petals .p.petal > i { border-radius: 100% 0 55% 50% / 55% 0 100% 50%; }
  /* leaf shape */
  #ambient-petals .p.leaf > i { border-radius: 0 100% 0 100% / 60% 40% 60% 40%; }
  /* flake / dot */
  #ambient-petals .p.flake > i { border-radius: 50%; filter: blur(0.4px); }

  /* soft drifting smoke puffs */
  #ambient-petals .smoke {
    position: absolute;
    left: var(--x, 50vw);
    width: var(--w, 260px);
    height: var(--w, 260px);
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, rgba(210, 214, 224, 0.55), rgba(210, 214, 224, 0) 68%);
    filter: blur(22px);
    opacity: 0;
    will-change: transform, opacity;
    animation: smoke-rise var(--fall, 24s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  /* faint horizontal "air flow" streaks */
  #ambient-petals .air {
    position: absolute;
    top: var(--y, 40vh);
    left: -40vw;
    width: 42vw;
    height: var(--h, 3px);
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
    filter: blur(6px);
    opacity: 0;
    will-change: transform, opacity;
    animation: air-flow var(--fall, 22s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  @keyframes drift-fall {
    0% { transform: translate(0, -12vh) rotate(0deg); }
    25% { transform: translate(22px, 20vh) rotate(90deg); }
    50% { transform: translate(-16px, 52vh) rotate(180deg); }
    75% { transform: translate(20px, 82vh) rotate(270deg); }
    100% { transform: translate(0, 116vh) rotate(360deg); }
  }
  @keyframes smoke-rise {
    0% { transform: translate(0, 25vh) scale(0.55); opacity: 0; }
    18% { opacity: var(--o, 0.12); }
    82% { opacity: var(--o, 0.12); }
    100% { transform: translate(48px, -32vh) scale(1.5); opacity: 0; }
  }
  @keyframes air-flow {
    0% { transform: translate(0, 0); opacity: 0; }
    14% { opacity: var(--o, 0.1); }
    86% { opacity: var(--o, 0.1); }
    100% { transform: translate(180vw, -22px); opacity: 0; }
  }
  @keyframes air-breathe {
    from { opacity: 0.7; }
    to { opacity: 1; }
  }

  /* equalizer bars shown while playing */
  .ambient-bars { height: 14px; }
  .ambient-bars i {
    display: block;
    width: 2.5px;
    height: 100%;
    border-radius: 2px;
    background: currentColor;
    transform-origin: bottom;
    animation: ambient-eq 1s ease-in-out infinite;
  }
  .ambient-bars i:nth-child(2) { animation-delay: 0.22s; }
  .ambient-bars i:nth-child(3) { animation-delay: 0.44s; }
  @keyframes ambient-eq {
    0%, 100% { transform: scaleY(0.35); }
    50% { transform: scaleY(1); }
  }

  #ambient-toggle.is-on { color: var(--foreground); }
  #ambient-toggle.is-on .ambient-icon { display: none; }
  #ambient-toggle.is-on .ambient-bars { display: inline-flex; }

  /* first-visit samurai hint over the sound button */
  #ambient-hint {
    transform: translateY(6px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  #ambient-hint.show { opacity: 1; transform: translateY(0); }
  .hint-bubble {
    padding: 5px 8px;
    border-radius: 8px;
    background: var(--foreground);
    color: var(--background);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }
  .hint-samurai {
    --samurai-dark: #3b3742;
    --samurai-gold: #cba24d;
    --samurai-face: #56515e;
    position: relative;
    display: block;
    animation: samurai-bob 1.9s ease-in-out infinite;
  }
  .hint-samurai svg { display: block; filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.22)); }
  .hint-samurai::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 8px;
    height: 8px;
    background: var(--samurai-face);
    transform: translateX(-50%) rotate(45deg);
    border-radius: 1px;
  }
  @keyframes samurai-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    #ambient-petals *,
    .ambient-bars i,
    .hint-samurai {
      animation: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const KEY = 'ambient-mode';
    const btn = document.getElementById('ambient-toggle');
    const audio = document.getElementById('ambient-audio');
    const layer = document.getElementById('ambient-petals');
    if (!btn || !audio || !layer) return;

    const TARGET = 0.32;
    const root = document.documentElement;
    let on = false;
    let built = false;
    let fadeTimer = 0;
    let animTimer = 0;

    const rand = (min, max) => min + Math.random() * (max - min);

    const PETAL_COLORS = ['#ffd9e6', '#fbb6ce', '#f9a8d4', '#ffe4ef', '#f7c8dc'];
    const LEAF_COLORS = ['#c8a24a', '#a8b56a', '#d0894a', '#b7c27a', '#caa15a'];
    const FLAKE_COLORS = ['#ffffff', '#fff2f7', '#f3f6ff'];

    const makeFalling = (type, colors, wMin, wMax, ratio, fallMin, fallMax, oMin, oMax) => {
      const el = document.createElement('div');
      el.className = 'p ' + type;
      el.style.setProperty('--x', rand(0, 100).toFixed(2) + 'vw');
      el.style.setProperty('--fall', rand(fallMin, fallMax).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, fallMax)).toFixed(2) + 's');
      const inner = document.createElement('i');
      const w = rand(wMin, wMax);
      inner.style.setProperty('--w', w.toFixed(1) + 'px');
      inner.style.setProperty('--h', (w * ratio).toFixed(1) + 'px');
      inner.style.setProperty('--o', rand(oMin, oMax).toFixed(2));
      inner.style.background = colors[(Math.random() * colors.length) | 0];
      el.appendChild(inner);
      return el;
    };

    const makeSmoke = () => {
      const el = document.createElement('div');
      el.className = 'smoke';
      el.style.setProperty('--x', rand(0, 100).toFixed(2) + 'vw');
      el.style.setProperty('--w', rand(200, 380).toFixed(0) + 'px');
      el.style.setProperty('--fall', rand(20, 34).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, 34)).toFixed(2) + 's');
      el.style.setProperty('--o', rand(0.06, 0.14).toFixed(3));
      return el;
    };

    const makeAir = () => {
      const el = document.createElement('div');
      el.className = 'air';
      el.style.setProperty('--y', rand(8, 88).toFixed(1) + 'vh');
      el.style.setProperty('--h', rand(2, 5).toFixed(1) + 'px');
      el.style.setProperty('--fall', rand(16, 30).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, 30)).toFixed(2) + 's');
      el.style.setProperty('--o', rand(0.05, 0.12).toFixed(3));
      return el;
    };

    const buildPetals = () => {
      if (built) return;
      built = true;
      const frag = document.createDocumentFragment();
      for (let i = 0; i < 10; i++) frag.appendChild(makeFalling('petal', PETAL_COLORS, 8, 16, 0.8, 10, 18, 0.6, 0.85));
      for (let i = 0; i < 6; i++) frag.appendChild(makeFalling('leaf', LEAF_COLORS, 12, 22, 0.62, 15, 26, 0.55, 0.8));
      for (let i = 0; i < 12; i++) frag.appendChild(makeFalling('flake', FLAKE_COLORS, 3, 6, 1, 12, 22, 0.35, 0.65));
      for (let i = 0; i < 4; i++) frag.appendChild(makeSmoke());
      for (let i = 0; i < 3; i++) frag.appendChild(makeAir());
      layer.appendChild(frag);
    };

    const fadeTo = (target) => {
      clearInterval(fadeTimer);
      const up = target > audio.volume;
      fadeTimer = window.setInterval(() => {
        let v = audio.volume + (up ? 0.03 : -0.04);
        if (v <= 0) { v = 0; audio.pause(); clearInterval(fadeTimer); }
        else if (v >= target && up) { v = target; clearInterval(fadeTimer); }
        else if (v <= target && !up) { clearInterval(fadeTimer); }
        audio.volume = Math.min(1, Math.max(0, v));
      }, 40);
    };

    const tryPlay = () => {
      audio.volume = 0;
      audio.play().then(() => fadeTo(TARGET)).catch(() => {
        // autoplay blocked (e.g. after navigation) — resume on next interaction
        const resume = () => {
          window.removeEventListener('pointerdown', resume);
          if (on && audio.paused) tryPlay();
        };
        window.addEventListener('pointerdown', resume, { once: true });
      });
    };

    const setOn = (state, withAudio) => {
      on = state;
      btn.classList.toggle('is-on', on);
      btn.setAttribute('aria-pressed', String(on));
      layer.style.opacity = on ? '1' : '0';
      // Japanese palette morph (smooth only during the toggle).
      root.classList.add('jp-anim');
      root.classList.toggle('jp', on);
      window.clearTimeout(animTimer);
      animTimer = window.setTimeout(() => root.classList.remove('jp-anim'), 700);
      localStorage.setItem(KEY, on ? '1' : '0');
      if (on) {
        buildPetals();
        if (withAudio) tryPlay();
      } else {
        fadeTo(0);
      }
    };

    btn.addEventListener('click', () => setOn(!on, true));

    // First-visit hint: a little samurai over the sound button.
    const HINT_KEY = 'ambient-hint-seen';
    const hint = document.getElementById('ambient-hint');
    if (hint) {
      if (localStorage.getItem(HINT_KEY) === '1' || localStorage.getItem(KEY) === '1') {
        hint.remove();
      } else {
        const dismiss = () => {
          localStorage.setItem(HINT_KEY, '1');
          hint.classList.remove('show');
          window.setTimeout(() => hint.remove(), 500);
        };
        window.setTimeout(() => hint.classList.add('show'), 900);
        btn.addEventListener('click', dismiss, { once: true });
        window.setTimeout(dismiss, 10000);
      }
    }

    if (localStorage.getItem(KEY) === '1') setOn(true, true);
  })();
</script>
