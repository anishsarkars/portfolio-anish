---
// Ambient "Japanese" mode: a subtle site-wide vibe toggle.
// When on, background music fades in and sakura petals drift through the air
// with a faint warm wash over the whole portfolio. Preference is remembered.
const track = '/music/hitslab-japan-japanese-music-502006.mp3';
---

<div
  id="ambient-petals"
  class="pointer-events-none fixed inset-0 z-[60] overflow-hidden opacity-0 transition-opacity duration-700"
  aria-hidden="true"
>
  <canvas id="ambient-canvas" class="absolute inset-0 block h-full w-full"></canvas>
</div>

<button
  id="ambient-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Toggle ambient music"
  title="Ambient mode"
  class="fixed bottom-5 right-5 z-[70] flex size-11 items-center justify-center rounded-full border border-border bg-background/70 text-foreground/70 shadow-sm backdrop-blur transition-colors hover:text-foreground"
>
  <svg class="ambient-icon size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9 18V5l12-2v13" />
    <circle cx="6" cy="18" r="3" />
    <circle cx="18" cy="16" r="3" />
  </svg>
  <span class="ambient-bars hidden items-end gap-[3px]" aria-hidden="true">
    <i></i><i></i><i></i>
  </span>
</button>

<div id="ambient-hint" class="pointer-events-none fixed bottom-[4.6rem] right-4 z-[71] flex items-end gap-2 opacity-0" aria-hidden="true">
  <span class="hint-bubble">Turn on sound</span>
  <span class="hint-samurai">
    <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <!-- maedate crest (crescent) -->
      <path d="M9 17C9 6 39 6 39 17C33 10 15 10 9 17Z" fill="var(--samurai-gold)" />
      <!-- helmet dome -->
      <path d="M11 30C11 18 37 18 37 30Z" fill="var(--samurai-dark)" />
      <path d="M24 19V30" stroke="var(--samurai-gold)" stroke-width="1.2" stroke-linecap="round" />
      <!-- fukigaeshi side flares -->
      <path d="M10 29L6 32L12 33Z" fill="var(--samurai-gold)" />
      <path d="M38 29L42 32L36 33Z" fill="var(--samurai-gold)" />
      <!-- menpo face -->
      <path d="M15 30H33V33C33 38 15 38 15 33Z" fill="var(--samurai-face)" />
      <path d="M18.5 33.2H22.5M25.5 33.2H29.5" stroke="var(--samurai-dark)" stroke-width="1.6" stroke-linecap="round" />
    </svg>
  </span>
</div>

<audio id="ambient-audio" src={track} loop preload="none"></audio>

<style>
  /* theme-aware particle tints (visible on both light + dark) */
  #ambient-petals {
    --flake-col: rgba(90, 104, 130, 0.6);
    --haze-col: rgba(228, 224, 228, 0.72);
    --air-col: rgba(90, 104, 130, 0.55);
  }
  :global(html.dark) #ambient-petals {
    --flake-col: rgba(255, 255, 255, 0.92);
    --haze-col: rgba(232, 230, 234, 0.82);
    --air-col: rgba(255, 255, 255, 0.9);
  }

  #ambient-petals::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(130% 75% at 50% 112%, rgba(198, 60, 82, 0.12), transparent 58%),
      radial-gradient(120% 60% at 50% -12%, rgba(255, 183, 206, 0.13), transparent 62%);
    animation: air-breathe 14s ease-in-out infinite alternate,
      wash-hue 34s linear infinite;
  }
  /* subtle cinematic vignette that slowly shifts colour all around the page */
  #ambient-petals::after {
    content: '';
    position: absolute;
    inset: 0;
    animation: vignette-cycle 32s ease-in-out infinite;
  }

  @keyframes wash-hue {
    from { filter: hue-rotate(0deg); }
    to { filter: hue-rotate(360deg); }
  }
  @keyframes vignette-cycle {
    0% { box-shadow: inset 0 0 170px 46px rgba(120, 22, 40, 0.11); }
    25% { box-shadow: inset 0 0 170px 46px rgba(58, 44, 120, 0.10); }
    50% { box-shadow: inset 0 0 170px 46px rgba(150, 96, 32, 0.10); }
    75% { box-shadow: inset 0 0 170px 46px rgba(30, 92, 92, 0.10); }
    100% { box-shadow: inset 0 0 170px 46px rgba(120, 22, 40, 0.11); }
  }

  /* shared drifting particles: petals, leaves, flakes — carried on a breeze */
  #ambient-petals .p {
    position: absolute;
    top: 0;
    left: var(--x, 50vw);
    will-change: transform, opacity;
    animation: breeze var(--fall, 16s) linear infinite;
    animation-delay: var(--delay, 0s);
  }
  #ambient-petals .p > i {
    display: block;
    width: var(--w, 12px);
    height: var(--h, 10px);
    opacity: var(--o, 0.7);
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.05));
  }
  /* petal shape */
  #ambient-petals .p.petal > i { border-radius: 100% 0 55% 50% / 55% 0 100% 50%; }
  /* leaf shape */
  #ambient-petals .p.leaf > i { border-radius: 0 100% 0 100% / 60% 40% 60% 40%; }
  /* flake / dot */
  #ambient-petals .p.flake > i {
    border-radius: 50%;
    filter: blur(0.3px) drop-shadow(0 0 2px rgba(0, 0, 0, 0.12));
  }

  /* soft haze/smoke puffs carried across on the breeze */
  #ambient-petals .smoke {
    position: absolute;
    left: var(--x, 50vw);
    top: var(--y, 20vh);
    width: var(--w, 260px);
    height: var(--w, 260px);
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, var(--haze-col), transparent 68%);
    filter: blur(22px);
    opacity: 0;
    will-change: transform, opacity;
    animation: smoke-drift var(--fall, 26s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  /* faint horizontal "air flow" streaks */
  #ambient-petals .air {
    position: absolute;
    top: var(--y, 40vh);
    left: -40vw;
    width: 42vw;
    height: var(--h, 3px);
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--air-col), transparent);
    filter: blur(6px);
    opacity: 0;
    will-change: transform, opacity;
    animation: air-flow var(--fall, 22s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  @keyframes breeze {
    0% { transform: translate3d(0, -14vh, 0) rotate(0deg); }
    20% { transform: translate3d(calc(var(--dx, 30vw) * 0.2 + 3vw), 14vh, 0) rotate(70deg); }
    45% { transform: translate3d(calc(var(--dx, 30vw) * 0.5 - 2vw), 42vh, 0) rotate(160deg); }
    70% { transform: translate3d(calc(var(--dx, 30vw) * 0.75 + 2vw), 72vh, 0) rotate(255deg); }
    100% { transform: translate3d(var(--dx, 30vw), 118vh, 0) rotate(360deg); }
  }
  @keyframes smoke-drift {
    0% { transform: translate3d(-24vw, 6vh, 0) scale(0.65); opacity: 0; }
    15% { opacity: var(--o, 0.16); }
    85% { opacity: var(--o, 0.16); }
    100% { transform: translate3d(64vw, -8vh, 0) scale(1.45); opacity: 0; }
  }
  @keyframes air-flow {
    0% { transform: translate(0, 0); opacity: 0; }
    14% { opacity: var(--o, 0.1); }
    86% { opacity: var(--o, 0.1); }
    100% { transform: translate(180vw, -22px); opacity: 0; }
  }
  @keyframes air-breathe {
    from { opacity: 0.7; }
    to { opacity: 1; }
  }

  /* equalizer bars shown while playing */
  .ambient-bars { height: 14px; }
  .ambient-bars i {
    display: block;
    width: 2.5px;
    height: 100%;
    border-radius: 2px;
    background: currentColor;
    transform-origin: bottom;
    animation: ambient-eq 1s ease-in-out infinite;
  }
  .ambient-bars i:nth-child(2) { animation-delay: 0.22s; }
  .ambient-bars i:nth-child(3) { animation-delay: 0.44s; }
  @keyframes ambient-eq {
    0%, 100% { transform: scaleY(0.35); }
    50% { transform: scaleY(1); }
  }

  #ambient-toggle.is-on { color: var(--foreground); }
  #ambient-toggle.is-on .ambient-icon { display: none; }
  #ambient-toggle.is-on .ambient-bars { display: inline-flex; }

  /* first-visit samurai hint over the sound button */
  #ambient-hint {
    transform: translateY(6px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  #ambient-hint.show { opacity: 1; transform: translateY(0); }
  .hint-bubble {
    padding: 5px 8px;
    border-radius: 8px;
    background: var(--foreground);
    color: var(--background);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }
  .hint-samurai {
    --samurai-dark: #3b3742;
    --samurai-gold: #cba24d;
    --samurai-face: #56515e;
    position: relative;
    display: block;
    animation: samurai-bob 1.9s ease-in-out infinite;
  }
  .hint-samurai svg { display: block; filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.22)); }
  .hint-samurai::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 8px;
    height: 8px;
    background: var(--samurai-face);
    transform: translateX(-50%) rotate(45deg);
    border-radius: 1px;
  }
  @keyframes samurai-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    #ambient-petals *,
    #ambient-petals::before,
    #ambient-petals::after,
    .ambient-bars i,
    .hint-samurai {
      animation: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const KEY = 'ambient-mode';
    const btn = document.getElementById('ambient-toggle');
    const audio = document.getElementById('ambient-audio');
    const layer = document.getElementById('ambient-petals');
    if (!btn || !audio || !layer) return;

    const TARGET = 0.32;
    const root = document.documentElement;
    let on = false;
    let built = false;
    let fadeTimer = 0;
    let animTimer = 0;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ===== Canvas snowfall (Originkit) — coral-red drift while sound is on =====
    const SNOW = {
      count: 355, sMin: 0.6, sMax: 0.7, sizeMin: 1, sizeMax: 4,
      oMin: 0.3, oMax: 0.77, wind: 0, windVar: 0.8, color: '#ff7f7f',
    };
    const canvas = document.getElementById('ambient-canvas');
    let sctx = null;
    let snowRaf = 0;
    let snowReady = false;
    let snowRO = null;
    let SW = 0;
    let SH = 0;
    let flakes = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rnd = (a, b) => a + Math.random() * (b - a);

    const snowBuild = () => {
      const rect = canvas.getBoundingClientRect();
      SW = Math.max(1, Math.floor(rect.width || window.innerWidth));
      SH = Math.max(1, Math.floor(rect.height || window.innerHeight));
      canvas.width = Math.floor(SW * dpr);
      canvas.height = Math.floor(SH * dpr);
      canvas.style.width = SW + 'px';
      canvas.style.height = SH + 'px';
      sctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = SNOW.count;
      flakes = new Array(n);
      for (let i = 0; i < n; i++) {
        flakes[i] = {
          x: Math.random() * SW, y: Math.random() * SH,
          r: rnd(SNOW.sizeMin, SNOW.sizeMax), vy: rnd(SNOW.sMin, SNOW.sMax),
          vx: rnd(-1, 1), phase: Math.random() * Math.PI * 2,
          sway: rnd(0.2, 0.9), alpha: rnd(SNOW.oMin, SNOW.oMax),
        };
      }
    };

    const snowDraw = () => {
      sctx.clearRect(0, 0, SW, SH);
      sctx.fillStyle = SNOW.color;
      for (let i = 0; i < flakes.length; i++) {
        const f = flakes[i];
        sctx.globalAlpha = f.alpha;
        sctx.beginPath();
        sctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        sctx.fill();
      }
      sctx.globalAlpha = 1;
    };

    const snowLoop = (t) => {
      for (let i = 0; i < flakes.length; i++) {
        const f = flakes[i];
        f.y += f.vy;
        f.x += SNOW.wind + f.vx * SNOW.windVar + Math.sin(t * 0.0012 + f.phase) * f.sway;
        if (f.y - f.r > SH) { f.y = -f.r; f.x = Math.random() * SW; }
        if (f.x < -f.r) f.x = SW + f.r;
        else if (f.x > SW + f.r) f.x = -f.r;
      }
      snowDraw();
      snowRaf = requestAnimationFrame(snowLoop);
    };

    const snowStart = () => {
      if (!canvas || reduceMotion) return;
      if (!snowReady) {
        sctx = canvas.getContext('2d');
        if (!sctx) return;
        snowBuild();
        snowReady = true;
        snowRO = new ResizeObserver(() => { snowBuild(); snowDraw(); });
        snowRO.observe(canvas);
      }
      if (!snowRaf) snowRaf = requestAnimationFrame(snowLoop);
    };

    const snowStop = () => {
      if (snowRaf) { cancelAnimationFrame(snowRaf); snowRaf = 0; }
    };

    const rand = (min, max) => min + Math.random() * (max - min);

    // crimson / sakura mix to match the cinematic reference
    const PETAL_COLORS = ['#e0566b', '#d24f61', '#e97d8f', '#c9455a', '#f2a8b6', '#db6076', '#fbb6ce'];
    const LEAF_COLORS = ['#c8a24a', '#a8b56a', '#d0894a', '#b7c27a', '#caa15a'];
    const FLAKE_COLORS = ['var(--flake-col)'];

    const makeFalling = (type, colors, wMin, wMax, ratio, fallMin, fallMax, oMin, oMax) => {
      const el = document.createElement('div');
      el.className = 'p ' + type;
      el.style.setProperty('--x', rand(-5, 95).toFixed(2) + 'vw');
      // horizontal breeze drift: mostly rightward, occasional turbulence left
      const dx = rand(10, 55) * (Math.random() < 0.18 ? -0.5 : 1);
      el.style.setProperty('--dx', dx.toFixed(1) + 'vw');
      el.style.setProperty('--fall', rand(fallMin, fallMax).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, fallMax)).toFixed(2) + 's');
      const inner = document.createElement('i');
      const w = rand(wMin, wMax);
      inner.style.setProperty('--w', w.toFixed(1) + 'px');
      inner.style.setProperty('--h', (w * ratio).toFixed(1) + 'px');
      inner.style.setProperty('--o', rand(oMin, oMax).toFixed(2));
      inner.style.background = colors[(Math.random() * colors.length) | 0];
      el.appendChild(inner);
      return el;
    };

    const makeSmoke = (lowBias) => {
      const el = document.createElement('div');
      el.className = 'smoke';
      el.style.setProperty('--x', rand(-5, 85).toFixed(2) + 'vw');
      // billowing clouds sit lower on the screen; some drift higher
      el.style.setProperty('--y', (lowBias ? rand(46, 92) : rand(6, 70)).toFixed(1) + 'vh');
      el.style.setProperty('--w', (lowBias ? rand(420, 680) : rand(280, 480)).toFixed(0) + 'px');
      el.style.setProperty('--fall', rand(26, 44).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, 44)).toFixed(2) + 's');
      el.style.setProperty('--o', (lowBias ? rand(0.28, 0.5) : rand(0.18, 0.36)).toFixed(3));
      return el;
    };

    const makeAir = () => {
      const el = document.createElement('div');
      el.className = 'air';
      el.style.setProperty('--y', rand(6, 90).toFixed(1) + 'vh');
      el.style.setProperty('--h', rand(2, 6).toFixed(1) + 'px');
      el.style.setProperty('--fall', rand(14, 26).toFixed(2) + 's');
      el.style.setProperty('--delay', (-rand(0, 26)).toFixed(2) + 's');
      el.style.setProperty('--o', rand(0.16, 0.32).toFixed(3));
      return el;
    };

    const buildPetals = () => {
      if (built) return;
      built = true;
      const frag = document.createDocumentFragment();
      for (let i = 0; i < 26; i++) frag.appendChild(makeFalling('petal', PETAL_COLORS, 9, 20, 0.8, 11, 22, 0.75, 0.96));
      for (let i = 0; i < 8; i++) frag.appendChild(makeFalling('leaf', LEAF_COLORS, 13, 24, 0.62, 16, 30, 0.65, 0.9));
      for (let i = 0; i < 18; i++) frag.appendChild(makeFalling('flake', FLAKE_COLORS, 4, 9, 1, 14, 26, 0.6, 0.95));
      for (let i = 0; i < 6; i++) frag.appendChild(makeSmoke(true));
      for (let i = 0; i < 4; i++) frag.appendChild(makeSmoke(false));
      for (let i = 0; i < 4; i++) frag.appendChild(makeAir());
      layer.appendChild(frag);
    };

    const fadeTo = (target) => {
      clearInterval(fadeTimer);
      const up = target > audio.volume;
      fadeTimer = window.setInterval(() => {
        let v = audio.volume + (up ? 0.03 : -0.04);
        if (v <= 0) { v = 0; audio.pause(); clearInterval(fadeTimer); }
        else if (v >= target && up) { v = target; clearInterval(fadeTimer); }
        else if (v <= target && !up) { clearInterval(fadeTimer); }
        audio.volume = Math.min(1, Math.max(0, v));
      }, 40);
    };

    const tryPlay = () => {
      audio.volume = 0;
      audio.play().then(() => fadeTo(TARGET)).catch(() => {
        // autoplay blocked (e.g. after navigation) — resume on next interaction
        const resume = () => {
          window.removeEventListener('pointerdown', resume);
          if (on && audio.paused) tryPlay();
        };
        window.addEventListener('pointerdown', resume, { once: true });
      });
    };

    const setOn = (state, withAudio) => {
      on = state;
      btn.classList.toggle('is-on', on);
      btn.setAttribute('aria-pressed', String(on));
      layer.style.opacity = on ? '1' : '0';
      // Japanese palette morph (smooth only during the toggle).
      root.classList.add('jp-anim');
      root.classList.toggle('jp', on);
      window.clearTimeout(animTimer);
      animTimer = window.setTimeout(() => root.classList.remove('jp-anim'), 700);
      localStorage.setItem(KEY, on ? '1' : '0');
      if (on) {
        buildPetals();
        snowStart();
        if (withAudio) tryPlay();
      } else {
        snowStop();
        fadeTo(0);
      }
    };

    btn.addEventListener('click', () => setOn(!on, true));

    // First-visit hint: a little samurai over the sound button.
    const HINT_KEY = 'ambient-hint-seen';
    const hint = document.getElementById('ambient-hint');
    if (hint) {
      if (localStorage.getItem(HINT_KEY) === '1' || localStorage.getItem(KEY) === '1') {
        hint.remove();
      } else {
        const dismiss = () => {
          localStorage.setItem(HINT_KEY, '1');
          hint.classList.remove('show');
          window.setTimeout(() => hint.remove(), 500);
        };
        window.setTimeout(() => hint.classList.add('show'), 900);
        btn.addEventListener('click', dismiss, { once: true });
        window.setTimeout(dismiss, 10000);
      }
    }

    if (localStorage.getItem(KEY) === '1') setOn(true, true);
  })();
</script>
